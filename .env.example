# NooBaa Fix Tool Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── SSH Jump Host ────────────────────────────────────────────────────────────
# Required when not using --direct mode.
SSH_HOST=
SSH_USER=
SSH_KEY=

# ── OpenShift ────────────────────────────────────────────────────────────────
# Path to kubeconfig on the jump host (SSH mode) or local machine (direct mode).
KUBECONFIG=

# OpenShift namespace where NooBaa/ODF is deployed.
NAMESPACE=openshift-storage
